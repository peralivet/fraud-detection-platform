# Application
APP_ENV=development
APP_NAME=fraud-detection-platform
LOG_LEVEL=INFO

# API
API_HOST=127.0.0.1
API_PORT=8000

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default

# Databricks
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=replace-with-local-token-only
DATABRICKS_CLUSTER_ID=replace-with-cluster-id

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=fraud-detection-platform

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=app_db
DATABASE_USER=app_user
DATABASE_PASSWORD=replace-with-local-password-only

# Feature Flags
ENABLE_DEBUG_MODE=true
ENABLE_MODEL_MONITORING=false
